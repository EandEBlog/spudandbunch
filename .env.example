# Spud & Bunch — environment variables.
# Copy to `.env` and fill in real values. `.env` is gitignored; never commit it.

# --- Frontend (apps/web) -------------------------------------------------
# Base URL of the Strapi content API the Astro build fetches from.
PUBLIC_STRAPI_URL=http://localhost:1337

# --- Added in later phases ----------------------------------------------
# Strapi (apps/cms): DB connection, app keys, admin JWT secrets — Phase 2.
# rebuild-hook: shared webhook secret — Phase 6.
# preview service: auth secret — Phase 7.
