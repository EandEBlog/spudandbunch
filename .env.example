# Spud & Bunch — environment for the PRODUCTION stack (docker-compose.yml).
# Copy to `.env` and fill in real values. `.env` is gitignored; never commit it.
# Generate each secret uniquely, e.g.  openssl rand -base64 16
#
# (The dev stack, docker-compose.dev.yml, uses apps/cms/.env instead.)

# --- Database ------------------------------------------------------------
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=change-me
DATABASE_NAME=strapi

# --- Strapi secrets ------------------------------------------------------
# APP_KEYS is a comma-separated list.
APP_KEYS=key1==,key2==,key3==,key4==
API_TOKEN_SALT=change-me
ADMIN_JWT_SECRET=change-me
TRANSFER_TOKEN_SALT=change-me
ENCRYPTION_KEY=change-me
JWT_SECRET=change-me

# --- rebuild-hook --------------------------------------------------------
# Shared secret: Strapi sends it as the X-Webhook-Secret header; the hook checks it.
WEBHOOK_SECRET=change-me

# --- web (Caddy) ---------------------------------------------------------
# ":80" = plain HTTP (no domain). Set to your domain (e.g. spudandbunch.com)
# for automatic HTTPS. Optionally override published host ports.
SITE_ADDRESS=:80
# HTTP_PORT=80
# HTTPS_PORT=443
# STRAPI_PORT=1337
