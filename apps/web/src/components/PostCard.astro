---
import type { Post } from '../lib/types';
import StrapiImage from './StrapiImage.astro';

interface Props {
  post: Post;
}
const { post } = Astro.props;
const href = `/posts/${post.slug}`;
const isRecipe = Boolean(post.recipe);
---

<article class="card">
  <a href={href} class="card-link">
    {
      post.coverImage ? (
        <StrapiImage image={post.coverImage} class="card-img" />
      ) : (
        <div class="card-img placeholder" aria-hidden="true" />
      )
    }
    <div class="card-body">
      {post.category && <span class="eyebrow">{post.category.name}</span>}
      <h3 class="card-title">{post.title}</h3>
      {post.excerpt && <p class="card-excerpt muted">{post.excerpt}</p>}
      {isRecipe && <span class="recipe-badge">🍳 Recipe</span>}
    </div>
  </a>
</article>

<style>
  .card {
    break-inside: avoid;
    margin-bottom: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition:
      transform 0.15s ease,
      box-shadow 0.15s ease;
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 28px var(--color-shadow);
  }
  .card-link {
    color: inherit;
    text-decoration: none;
    display: block;
  }
  .card-link:hover {
    text-decoration: none;
  }
  .card :global(.card-img) {
    width: 100%;
    height: auto;
    display: block;
  }
  .placeholder {
    aspect-ratio: 4 / 3;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
  }
  .card-body {
    padding: var(--space-4);
  }
  .card-title {
    font-size: var(--text-lg);
    margin: var(--space-1) 0 var(--space-2);
  }
  .card-excerpt {
    font-size: var(--text-sm);
    margin: 0;
  }
  .recipe-badge {
    display: inline-block;
    margin-top: var(--space-3);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-primary-dark);
  }
</style>
