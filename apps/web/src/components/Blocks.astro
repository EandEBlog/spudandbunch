---
// Renders Strapi "blocks" rich content. Text blocks (paragraphs, headings,
// lists, quotes, code) are emitted as escaped HTML. Image blocks are rendered
// through Astro's <Image> so inline body images are optimized and baked into the
// static build — self-hosted, with no runtime dependency on Strapi (same as the
// cover image).
import StrapiImage from './StrapiImage.astro';
import { mediaUrl } from '../lib/strapi';
import type { ImageAsset } from '../lib/types';

interface Props {
  content: unknown;
}
const { content } = Astro.props;

function esc(s: unknown): string {
  return String(s ?? '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

/* eslint-disable @typescript-eslint/no-explicit-any */
function inlineToHtml(node: any): string {
  if (node?.type === 'link') {
    const inner = (node.children ?? []).map(inlineToHtml).join('');
    return `<a href="${esc(node.url)}" rel="noopener">${inner}</a>`;
  }
  let t = esc(node?.text ?? '');
  if (!t) return '';
  if (node.code) t = `<code>${t}</code>`;
  if (node.bold) t = `<strong>${t}</strong>`;
  if (node.italic) t = `<em>${t}</em>`;
  if (node.underline) t = `<u>${t}</u>`;
  if (node.strikethrough) t = `<s>${t}</s>`;
  return t;
}

function childrenHtml(children: any[] | undefined): string {
  return (children ?? []).map(inlineToHtml).join('');
}

// HTML for a single non-image block. Image blocks are handled in the template.
function blockToHtml(b: any): string {
  switch (b?.type) {
    case 'paragraph': {
      const inner = childrenHtml(b.children);
      return inner.trim() ? `<p>${inner}</p>` : '';
    }
    case 'heading': {
      const lvl = Math.min(Math.max(Number(b.level) || 2, 1), 6);
      return `<h${lvl}>${childrenHtml(b.children)}</h${lvl}>`;
    }
    case 'list': {
      const tag = b.format === 'ordered' ? 'ol' : 'ul';
      const items = (b.children ?? [])
        .map((li: any) => `<li>${childrenHtml(li.children)}</li>`)
        .join('');
      return `<${tag}>${items}</${tag}>`;
    }
    case 'quote':
      return `<blockquote>${childrenHtml(b.children)}</blockquote>`;
    case 'code':
      return `<pre><code>${esc((b.children ?? []).map((c: any) => c.text ?? '').join('\n'))}</code></pre>`;
    default: {
      const inner = childrenHtml(b.children);
      return inner ? `<p>${inner}</p>` : '';
    }
  }
}

// Map a block's image object to our ImageAsset (absolute URL + dimensions).
function toImageAsset(b: any): ImageAsset | null {
  const url = mediaUrl(b?.image?.url);
  if (!url) return null;
  return {
    url,
    alt: b.image?.alternativeText ?? '',
    width: b.image?.width,
    height: b.image?.height,
  };
}
/* eslint-enable @typescript-eslint/no-explicit-any */

const blocks: unknown[] = Array.isArray(content) ? content : [];
---

<div class="prose-body">
  {
    blocks.map((block) => {
      if ((block as { type?: string })?.type === 'image') {
        const img = toImageAsset(block);
        return img ? <StrapiImage image={img} class="body-img" /> : null;
      }
      return <Fragment set:html={blockToHtml(block)} />;
    })
  }
</div>

<style>
  .prose-body :global(p),
  .prose-body :global(ul),
  .prose-body :global(ol),
  .prose-body :global(blockquote),
  .prose-body :global(pre) {
    margin: 0 0 var(--space-4);
  }
  .prose-body :global(h2),
  .prose-body :global(h3) {
    margin-top: var(--space-8);
  }
  .prose-body :global(.body-img),
  .prose-body :global(img) {
    border-radius: var(--radius);
    margin: var(--space-6) 0;
    width: 100%;
    height: auto;
  }
  .prose-body :global(blockquote) {
    border-left: 3px solid var(--color-primary);
    padding-left: var(--space-4);
    color: var(--color-muted);
    font-style: italic;
  }
  .prose-body :global(pre) {
    background: #2b2420;
    color: #f5efe7;
    padding: var(--space-4);
    border-radius: var(--radius);
    overflow-x: auto;
    font-size: var(--text-sm);
  }
</style>
