---
import BaseLayout from './BaseLayout.astro';
import Blocks from '../components/Blocks.astro';
import RecipeCard from '../components/RecipeCard.astro';
import TagList from '../components/TagList.astro';
import StrapiImage from '../components/StrapiImage.astro';
import type { Post } from '../lib/types';

interface Props {
  post: Post;
}
const { post } = Astro.props;

const date = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<BaseLayout title={post.title} description={post.excerpt}>
  <article class="container post">
    <header class="post-header prose">
      {
        post.category && (
          <a href={`/category/${post.category.slug}`} class="eyebrow">
            {post.category.name}
          </a>
        )
      }
      <h1>{post.title}</h1>
      <p class="meta muted">
        {post.author && <span>By {post.author.name}</span>}
        {post.author && date && <span> · </span>}
        {date && <span>{date}</span>}
      </p>
    </header>

    {
      post.coverImage && (
        <StrapiImage
          image={post.coverImage}
          class="cover"
          loading="eager"
          sizes="(min-width: 48rem) 42rem, 100vw"
        />
      )
    }

    <div class="prose post-content">
      <Blocks content={post.body} />
      {post.recipe && <RecipeCard recipe={post.recipe} />}
      <TagList tags={post.tags} />
    </div>
  </article>

  <style>
    .post {
      padding-block: var(--space-8);
    }
    .post-header,
    .post-content {
      margin-inline: auto;
    }
    .post-header h1 {
      margin: var(--space-2) 0;
    }
    .meta {
      font-size: var(--text-sm);
    }
    .post :global(.cover) {
      width: 100%;
      height: auto;
      border-radius: var(--radius-lg);
      margin: var(--space-6) auto var(--space-8);
      max-width: var(--content-width);
    }
  </style>
</BaseLayout>
