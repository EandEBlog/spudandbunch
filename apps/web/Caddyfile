# Caddy serves the static site from the shared volume at /srv.
#
# SITE_ADDRESS controls the listen address:
#   - default ":80"  → plain HTTP (no domain yet)
#   - set to a domain (e.g. "spudandbunch.com") → Caddy gets automatic HTTPS
#     from Let's Encrypt with no extra config.
{$SITE_ADDRESS::80} {
	root * /srv
	encode gzip zstd
	file_server

	handle_errors {
		@404 expression {err.status_code} == 404
		rewrite @404 /404.html
		file_server
	}
}
