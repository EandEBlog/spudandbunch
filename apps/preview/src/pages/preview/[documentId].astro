---
export const prerender = false;

// Reuse the production post template + data layer from apps/web so the preview
// is pixel-identical to the published page.
import PostLayout from '../../../../web/src/layouts/PostLayout.astro';
import { getDraftPost } from '../../../../web/src/lib/content';

const { documentId } = Astro.params;

// Gate: the URL must carry the shared secret (supplied by Strapi's Preview button).
const expected = process.env.PREVIEW_SECRET;
const provided = new URL(Astro.request.url).searchParams.get('secret');
if (!expected || provided !== expected) {
  return new Response('Unauthorized', { status: 401 });
}

const post = documentId ? await getDraftPost(documentId) : null;
if (!post) {
  return new Response('Draft not found', { status: 404 });
}
---

<PostLayout post={post} preview />
